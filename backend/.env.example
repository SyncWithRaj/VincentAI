PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────────────
# APIFY (powers Instagram, Twitter, LinkedIn analytics — no OAuth required)
# ──────────────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=

# Default social handles (used when no query param is passed)
INSTAGRAM_DEFAULT_USERNAME=your_instagram_username
TWITTER_DEFAULT_USERNAME=your_twitter_handle
LINKEDIN_DEFAULT_PROFILE_URL=https://www.linkedin.com/in/your-username/
TWITTER_FALLBACK_ACTOR=gentle_cloud~twitter-tweets-scraper
LINKEDIN_FALLBACK_ACTOR=

# ──────────────────────────────────────────────────────────────────────────────
# YouTube Data API v3  (still uses official API — no Apify needed)
# ──────────────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# YouTube Analytics API (OAuth required for reach/impressions)
# Option A: Short-lived OAuth access token
YOUTUBE_OAUTH_ACCESS_TOKEN=

# Option B: Refresh-token flow (recommended for long-running backend)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Analytics lookback window in days
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=28

# ──────────────────────────────────────────────────────────────────────────────
# AI / LLM Pipeline
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
TAVILY_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Trends — Spotify Charts
# ──────────────────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Social Publishing (Create Post with AI -> one-click distribution)
# ──────────────────────────────────────────────────────────────────────────────
# Shared Meta Graph version for Instagram/Facebook publish calls
META_GRAPH_API_VERSION=v25.0

# Instagram Reels publish (Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Facebook Page video publish (Video API)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# LinkedIn publish (Posts API)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_VERSION=202506
LINKEDIN_ENABLE_VIDEO_UPLOAD=false

# X/Twitter publish (v2 posts API)
X_ACCESS_TOKEN=
# Optional uploaded media ID (if you already upload media via your own X upload flow)
X_MEDIA_ID=

# Optional Composio bridge (if you route publishing through Composio workflows)
# IMPORTANT: This must be your outbound Composio executor/workflow endpoint.
# Do NOT set it to your inbound webhook receiver (/api/composio/webhook).
COMPOSIO_PUBLISH_WEBHOOK_URL=http://127.0.0.1:4000/api/composio/publish-exec
COMPOSIO_API_KEY=
COMPOSIO_WEBHOOK_SECRET=
COMPOSIO_EXECUTOR_TIMEOUT_SECONDS=180
COMPOSIO_INSTAGRAM_MAX_WAIT_SECONDS=240
COMPOSIO_INSTAGRAM_POLL_INTERVAL_SECONDS=3

# Optional Composio execution tuning
COMPOSIO_USER_ID=aify_default_user
COMPOSIO_INSTAGRAM_TOOL_SLUG=
COMPOSIO_LINKEDIN_TOOL_SLUG=
COMPOSIO_TWITTER_TOOL_SLUG=
COMPOSIO_FACEBOOK_TOOL_SLUG=
COMPOSIO_INSTAGRAM_ACCOUNT=
COMPOSIO_LINKEDIN_ACCOUNT=
COMPOSIO_TWITTER_ACCOUNT=
COMPOSIO_FACEBOOK_ACCOUNT=
